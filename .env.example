# CinePhix Backend - Environment Variables
# Copy this file to .env and fill in the values

# Docker Compose: published host port for the API (inside the container it stays 8000)
# API_HOST_PORT=8001

# App
APP_NAME="CinePhix API"
APP_VERSION="0.1.0"
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/cinephix

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# TMDB API Key (from .env in CinePhix frontend)
TMDB_API_KEY=e546f0210838c597382ddcad9f8e0647
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# Email (Resend - https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=CinePhix <noreply@cinephix.com>

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=  # Set after running: stripe listen --forward-to localhost:8000/payments/webhook
FRONTEND_URL=http://localhost:3000

# Groq AI (https://console.groq.com)
GROQ_API_KEY=
